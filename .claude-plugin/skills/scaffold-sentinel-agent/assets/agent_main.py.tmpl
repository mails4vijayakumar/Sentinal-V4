def _verify_inbound_token(token: str) -> None:
    """Constant-time check of the inbound shared secret."""
    if not SHARED_SECRET:
        raise HTTPException(status_code=500, detail="agent {{N}} not configured (AGENT_{{N}}_SHARED_SECRET missing)")
    if not token or not hmac.compare_digest(token, SHARED_SECRET):
        raise HTTPException(status_code=401, detail="invalid inter-agent token")


@asynccontextmanager
async def lifespan(app: FastAPI) -> AsyncGenerator[None, None]:
    LOG.info("agent {{N}} ({{NAME}}) starting on port %d", PORT)
    yield
    LOG.info("agent {{N}} ({{NAME}}) stopped")


app = FastAPI(title="Sentinel Agent {{N}} — {{NAME}}", lifespan=lifespan)


