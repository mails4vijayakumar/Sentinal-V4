# ─────────────────────────────────────────────────────────────────────────────
#  Sentinel — Environment Configuration
#  cp .env.example .env  then fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Routing DB ────────────────────────────────────────────────────────────────
# Admin token for all /admin/* writes (generate: openssl rand -base64 48)
ROUTING_DB_ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN
# Read token (leave empty to make /reads/* public)
ROUTING_DB_READ_TOKEN=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: ollama | anthropic | openai
LLM_PROVIDER=ollama

# Ollama (default — fully local, no data leaves the network)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text

# Anthropic Claude (requires signed BAA for PHI-adjacent environments)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (requires signed BAA for PHI-adjacent environments)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Dynatrace ─────────────────────────────────────────────────────────────────
DT_BASE_URL=https://XXXXXXXX.live.dynatrace.com
DT_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# HMAC-SHA256 secret set in DT webhook configuration
DT_WEBHOOK_SECRET=CHANGE_ME

# ── ServiceNow ────────────────────────────────────────────────────────────────
SNOW_BASE_URL=https://your-instance.service-now.com
# Auth mode: oauth (preferred) | basic
SNOW_AUTH_MODE=oauth
SNOW_CLIENT_ID=
SNOW_CLIENT_SECRET=
# Basic-auth fallback (when SNOW_AUTH_MODE=basic)
SNOW_USERNAME=sentinel_integration
SNOW_PASSWORD=CHANGE_ME
SNOW_CALLER_ID=sentinel.agent@hospital.org
# HMAC secret for SNOW outbound Business Rule webhooks
SNOW_WEBHOOK_SECRET=CHANGE_ME

# ── Splunk ────────────────────────────────────────────────────────────────────
SPLUNK_BASE_URL=https://splunk.internal:8089
SPLUNK_TOKEN=
SPLUNK_INDEX=main

# ── Confluence ────────────────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_TOKEN=

# ── PagerDuty ─────────────────────────────────────────────────────────────────
PD_API_KEY=
PD_SERVICE_ID=
PD_FROM_EMAIL=sentinel-alerts@your-org.com

# ── Notifications ─────────────────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=ops-team@your-org.com

# ── Webapp ────────────────────────────────────────────────────────────────────
# Public URL of Agent 1 reachable from the browser
VITE_API_BASE=http://localhost:8001
VITE_ROUTING_DB_BASE=http://localhost:8000

# ── Agent 8 (Knowledge Synthesizer) ──────────────────────────────────────────
# Monthly batch agent on port 8008. Off the 60-s critical path.
# See agents/Agent-8-knowledge-synth/AGENTS.md for the full operational guide.

# Cron expression — APScheduler format. Default: day 1 of every month at 02:00.
SYNTH_SCHEDULE_CRON="0 2 1 * *"

# Clustering thresholds
SYNTH_MIN_CLUSTER_SIZE=5
SYNTH_MIN_SAMPLES=3
SYNTH_MIN_CLUSTER_COHESION=0.65
SYNTH_QUALITY_SCORE_FLOOR=0.40

# Dedup decision bands (cosine similarity)
SYNTH_DEDUP_UPDATE_THRESHOLD=0.92
SYNTH_DEDUP_REVIEW_THRESHOLD=0.80

# Synthesis LLM + cost ceiling (tokens per run)
SYNTH_LLM_MODEL=llama3.1:70b
SYNTH_LLM_MAX_TOKENS_PER_RUN=500000  # Reserved for future use — not yet enforced by Agent 8

# Confluence publication
SYNTH_PUBLISH_CONFLUENCE=true
SYNTH_CONFLUENCE_SPACE=AUTO_KB

# Retirement of low-utility articles based on feedback signals
SYNTH_RETIRE_LOW_FEEDBACK=true

# Admin token for POST /jobs/synthesize (backfill + ad-hoc runs).
# REQUIRED in production — empty value disables the endpoint.
SYNTH_ADMIN_TOKEN=

# Bounded concurrency for LLM synthesis fan-out per run
SYNTH_MAX_CONCURRENT_SYNTHESIZE=10
