# ─────────────────────────────────────────────────────────────────────────────
#  Sentinel — Environment Configuration
#  cp .env.example .env  then fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Routing DB ────────────────────────────────────────────────────────────────
# Admin token for all /admin/* writes (generate: openssl rand -base64 48)
ROUTING_DB_ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN
# Read token (leave empty to make /reads/* public)
ROUTING_DB_READ_TOKEN=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: ollama | anthropic | openai
LLM_PROVIDER=ollama

# Ollama (default — fully local, no data leaves the network)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text

# Anthropic Claude (requires signed BAA for PHI-adjacent environments)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (requires signed BAA for PHI-adjacent environments)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Dynatrace ─────────────────────────────────────────────────────────────────
DT_BASE_URL=https://XXXXXXXX.live.dynatrace.com
DT_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# HMAC-SHA256 secret set in DT webhook configuration
DT_WEBHOOK_SECRET=CHANGE_ME

# ── ServiceNow ────────────────────────────────────────────────────────────────
SNOW_BASE_URL=https://your-instance.service-now.com
# Auth mode: oauth (preferred) | basic
SNOW_AUTH_MODE=oauth
SNOW_CLIENT_ID=
SNOW_CLIENT_SECRET=
# Basic-auth fallback (when SNOW_AUTH_MODE=basic)
SNOW_USERNAME=sentinel_integration
SNOW_PASSWORD=CHANGE_ME
SNOW_CALLER_ID=sentinel.agent@hospital.org
# HMAC secret for SNOW outbound Business Rule webhooks
SNOW_WEBHOOK_SECRET=CHANGE_ME

# ── Splunk ────────────────────────────────────────────────────────────────────
SPLUNK_BASE_URL=https://splunk.internal:8089
SPLUNK_TOKEN=
SPLUNK_INDEX=main

# ── Confluence ────────────────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_TOKEN=

# ── PagerDuty ─────────────────────────────────────────────────────────────────
PD_API_KEY=
PD_SERVICE_ID=
PD_FROM_EMAIL=sentinel-alerts@your-org.com

# ── Notifications ─────────────────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=ops-team@your-org.com

# ── Webapp ────────────────────────────────────────────────────────────────────
# Public URL of Agent 1 reachable from the browser
VITE_API_BASE=http://localhost:8001
VITE_ROUTING_DB_BASE=http://localhost:8000
